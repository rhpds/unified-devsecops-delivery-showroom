#!/bin/bash
set -e

# Test script for programmatic git commit signing with RHTAS and Keycloak
# This script authenticates user and signs a commit using gitsign
# Template variables are substituted by Ansible

echo "========================================="
echo "Testing Programmatic Commit Signing"
echo "========================================="

# Configuration from Ansible variables
KEYCLOAK_URL="{{ keycloak_admin_console }}"
TAS_FULCIO_URL="{{ tas_fulcio_url }}"
TAS_REKOR_URL="{{ tas_rekor_url }}"
TAS_TUF_URL="{{ tas_tuf_url }}"
TAS_CHAINS_REALM="{{ tas_chains_realm }}"
TAS_SSO_REALM="{{ tas_sso_realm }}"
TAS_CHAINS_CLIENT_ID="{{ tas_chains_client_id }}"
USERNAME="{{ user }}"
PASSWORD="{{ password }}"
GITLAB_URL="{{ gitlab_url }}"
CLUSTER_DOMAIN="{{ openshift_cluster_ingress_domain }}"

{% raw %}

echo "Configuration:"
echo "  Username: $USERNAME"
echo "  Keycloak: $KEYCLOAK_URL"
echo "  Client ID: $TAS_CHAINS_CLIENT_ID"
echo "  SSO Realm (for auth): $TAS_SSO_REALM"
echo "  Chains Realm (for signing): $TAS_CHAINS_REALM"
echo "  Fulcio URL: $TAS_FULCIO_URL"
echo "  Rekor URL: $TAS_REKOR_URL"
echo "  TUF URL: $TAS_TUF_URL"
echo "  Cluster domain: $CLUSTER_DOMAIN"

# Download and install gitsign CLI
echo ""
echo "Installing gitsign CLI..."
GITSIGN_CLI_URL="https://cli-server-trusted-artifact-signer.${CLUSTER_DOMAIN}/clients/linux/gitsign-amd64.gz"
echo "Downloading from: $GITSIGN_CLI_URL"

GITSIGN_BIN="/tmp/gitsign-$$"
if curl -k -s -L "$GITSIGN_CLI_URL" | gunzip > "$GITSIGN_BIN"; then
  chmod +x "$GITSIGN_BIN"
  echo "✓ gitsign installed to $GITSIGN_BIN"

  # Verify it works
  if "$GITSIGN_BIN" version >/dev/null 2>&1; then
    echo "✓ gitsign version: $("$GITSIGN_BIN" version 2>/dev/null | head -1)"
  else
    echo "⚠ gitsign installed but version check failed"
  fi
else
  echo "ERROR: Failed to download gitsign"
  exit 1
fi

# Build token endpoint (use SSO realm for authentication)
TOKEN_ENDPOINT="$KEYCLOAK_URL/realms/$TAS_SSO_REALM/protocol/openid-connect/token"
echo ""
echo "Token endpoint: $TOKEN_ENDPOINT"

# Get access token for user
echo ""
echo "Authenticating $USERNAME via SSO realm and getting access token..."
TOKEN_RESPONSE=$(curl -k -s -X POST "$TOKEN_ENDPOINT" \
  -H "Content-Type: application/x-www-form-urlencoded" \
  -d "client_id=$TAS_CHAINS_CLIENT_ID" \
  -d "username=$USERNAME" \
  -d "password=$PASSWORD" \
  -d "grant_type=password" \
  -d "scope=openid email profile")

# Check if we got a token (using Python instead of jq)
ACCESS_TOKEN=$(echo "$TOKEN_RESPONSE" | python3 -c "import sys, json; data=json.load(sys.stdin); print(data.get('access_token', ''))" 2>/dev/null)
if [ -z "$ACCESS_TOKEN" ]; then
  echo "ERROR: Failed to get access token"
  echo "Response: $TOKEN_RESPONSE"
  exit 1
fi

echo "✓ Access token obtained (length: ${#ACCESS_TOKEN})"
ID_TOKEN=$(echo "$TOKEN_RESPONSE" | python3 -c "import sys, json; data=json.load(sys.stdin); print(data.get('id_token', ''))" 2>/dev/null)
echo "✓ ID token obtained (length: ${#ID_TOKEN})"

# Decode and display token info
echo ""
echo "Token claims:"
echo "$ID_TOKEN" | cut -d'.' -f2 | base64 -d 2>/dev/null | python3 -c "import sys, json; data=json.load(sys.stdin); print(data.get('email', '')); print(data.get('preferred_username', '')); print(data.get('sub', ''))" 2>/dev/null | head -3

# Test gitsign configuration
echo ""
echo "========================================="
echo "Testing gitsign with obtained token"
echo "========================================="

# Clone my-quarkus-tkn repo from GitLab
REPO_NAME="my-quarkus-tkn"
REPO_PATH="/tmp/${REPO_NAME}-$$"

echo "Cloning repository: development/${REPO_NAME}"
echo "Repository path: $REPO_PATH"

# Build Git URL with credentials
GIT_URL=$(echo "$GITLAB_URL" | sed "s|https://|https://${USERNAME}:${PASSWORD}@|")/development/${REPO_NAME}.git

# Clone the repository
if ! git clone "$GIT_URL" "$REPO_PATH" 2>&1; then
  echo "ERROR: Failed to clone repository"
  exit 1
fi

cd "$REPO_PATH"
echo "✓ Repository cloned successfully"

# Configure git for commit
git config user.email "${USERNAME}@edemo.redhat.com"
git config user.name "$USERNAME"

# Configure gitsign
echo ""
echo "Configuring gitsign..."
git config --local commit.gpgsign true
git config --local tag.gpgsign true
git config --local gpg.x509.program "$GITSIGN_BIN"
git config --local gpg.format x509

# Set gitsign environment variables
export GITSIGN_CONNECTOR_ID="$KEYCLOAK_URL/realms/$TAS_CHAINS_REALM"
export GITSIGN_OIDC_ISSUER="$KEYCLOAK_URL/realms/$TAS_CHAINS_REALM"
export GITSIGN_OIDC_CLIENT_ID="$TAS_CHAINS_CLIENT_ID"
export GITSIGN_FULCIO_URL="$TAS_FULCIO_URL"
export GITSIGN_REKOR_URL="$TAS_REKOR_URL"

# The key part - provide the ID token to gitsign
export GITSIGN_OIDC_TOKEN="$ID_TOKEN"

echo "GITSIGN_CONNECTOR_ID: $GITSIGN_CONNECTOR_ID"
echo "GITSIGN_OIDC_ISSUER: $GITSIGN_OIDC_ISSUER"
echo "GITSIGN_FULCIO_URL: $GITSIGN_FULCIO_URL"
echo "GITSIGN_REKOR_URL: $GITSIGN_REKOR_URL"

# Create a test file and commit
echo ""
echo "Creating test file..."
TIMESTAMP=$(date +%Y%m%d-%H%M%S)
TEST_FILE="test-signed-commit-${TIMESTAMP}.txt"
echo "This is a test file to verify commit signing with RHTAS" > "$TEST_FILE"
echo "Created by: $USERNAME" >> "$TEST_FILE"
echo "Timestamp: $(date)" >> "$TEST_FILE"

git add "$TEST_FILE"

# Attempt to commit with signature
echo ""
echo "Attempting signed commit..."
if git commit -m "Add test file to verify commit signing

This commit tests programmatic commit signing using:
- RHTAS (Fulcio/Rekor)
- Keycloak OIDC authentication
- gitsign for transparent signing

File: $TEST_FILE" 2>&1 | tee /tmp/commit-output.txt; then
  echo ""
  echo "✓ Commit succeeded!"

  # Verify the signature
  echo ""
  echo "Verifying commit signature..."
  git log --show-signature -1

  # Push to GitLab
  echo ""
  echo "Pushing signed commit to GitLab..."
  if git push origin master 2>&1; then
    echo "✓ Push succeeded!"
  else
    echo "✗ Push failed - check if branch exists or permissions"
  fi

  echo ""
  echo "========================================="
  echo "SUCCESS: Commit signing works!"
  echo "========================================="
  echo "Repository: development/${REPO_NAME}"
  echo "Signed commit: $(git rev-parse HEAD)"
else
  echo ""
  echo "✗ Commit failed"
  echo "Output:"
  cat /tmp/commit-output.txt
  exit 1
fi

# Cleanup
cd /
rm -rf "$REPO_PATH"
rm -f "$GITSIGN_BIN"
{% endraw %}
